generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Blog engagement ──

enum ReactionType {
  LIKE
  CLAP
}

model Reaction {
  id        String       @id @default(cuid())
  slug      String
  voterId   String
  type      ReactionType
  createdAt DateTime     @default(now())

  @@unique([slug, voterId, type])
  @@index([slug])
}

model Comment {
  id           String   @id @default(cuid())
  slug         String
  body         String
  authorName   String
  authorAvatar String?
  authorGithub String
  createdAt    DateTime @default(now())

  @@index([slug])
}

model View {
  id   String @id @default(cuid())
  slug String @unique
  count Int   @default(0)
}
