# Copy this to .env.production and fill in your values
# NEVER commit .env.production to git

# Spotify API (if using)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# GitHub API (if using)
GITHUB_TOKEN=

# Last.fm API (if using)
LASTFM_API_KEY=
LASTFM_USERNAME=

# Database (matches docker-compose db service)
DATABASE_URL=postgresql://portfolio:portfolio@db:5432/portfolio?schema=public

# NextAuth (generate secret with: openssl rand -base64 32)
AUTH_SECRET=
AUTH_URL=https://yourdomain.com

# GitHub OAuth for blog comments (create at https://github.com/settings/developers)
# Set callback URL to: https://yourdomain.com/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# Your GitHub username (for admin comment deletion)
ADMIN_GITHUB=
NEXT_PUBLIC_ADMIN_GITHUB=
